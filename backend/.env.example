# ===========================================================================
#  NutriAI Fit — TEMPLATE de variáveis de ambiente (versionado, SEM segredos)
#  Copie para .env e preencha. Gere SECRET_KEY com:
#    python -c "import secrets; print(secrets.token_hex(32))"
# ===========================================================================
ENVIRONMENT=development

# Use a senha que você definiu no provision_db.sql:
DATABASE_URL=postgresql+psycopg2://nutriai:<SUA_SENHA_FORTE>@localhost:5432/nutriai_fit

SECRET_KEY=<gere_um_segredo_forte>
ACCESS_TOKEN_EXPIRE_MINUTES=10080

CORS_ORIGINS=*

AI_PROVIDER=mock          # mock | gemini
STORAGE_PROVIDER=local    # local | r2

UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:8000
MAX_UPLOAD_MB=10

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
